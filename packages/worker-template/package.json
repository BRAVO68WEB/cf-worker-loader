{
  "name": "@orcratration/worker-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "pnpm dev:loader",
    "dev:local": "wrangler dev --local",
    "dev:loader": "wrangler dev --config wrangler.loader.toml",
    "deploy": "wrangler deploy",
    "deploy:loader": "wrangler deploy --config wrangler.loader.toml",
    "clean": "rm -rf dist .wrangler",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@orcratration/shared": "workspace:*",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.62.0"
  }
}
