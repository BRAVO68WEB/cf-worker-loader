# Orcratration — copy to .env and fill in values.
# All packages that need env read from this file when run from repo root.

# Backend
MONGODB_URI=mongodb://localhost:27017/orcratration
PORT=3000
JWT_SECRET=your-secret-min-32-chars-for-jwt-signing

# Worker Loader (default): set to use dynamic isolates instead of one Worker per script.
# For local dev, run the loader: pnpm --filter @orcratration/worker-template dev:loader
# Then set LOADER_URL so the backend calls it on submit. Leave empty for one-Worker-per-script.
LOADER_URL=http://localhost:8787

# Cloudflare (only needed when LOADER_URL is not set — one Worker per script deploy)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
KV_NAMESPACE_ID=

# Frontend (optional; Vite loads from root .env, prefix with VITE_ to expose to client)
# VITE_API_URL=/api
